{
  "private": true,
  "workspaces": [
    "ember-statechart-component",
    "testing/*"
  ],
  "repository": "https://github.com/NullVoxPopuli/ember-statechart-component",
  "license": "MIT",
  "author": "NullVoxPopuli",
  "scripts": {
    "build": "pnpm --filter ember-statechart-component build",
    "prepare": "pnpm build",
    "lint": "pnpm run --filter '*' lint",
    "lint:fix": "pnpm run --filter '*' lint:fix"
  },
  "devDependencies": {
    "@babel/core": "7.23.7",
    "@typescript-eslint/parser": "^6.17.0",
    "ember-template-lint": "^5.13.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-ember": "github:ember-cli/eslint-plugin-ember#master",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.1",
    "release-plan": "^0.6.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.12.1",
  "pnpm": {
    "overrides": {
      "ember-eslint-parser": "0.2.5",
      "eslint-plugin-ember": "github:ember-cli/eslint-plugin-ember#master",
      "ember-cli-babel": "^8.2.0"
    },
    "packageExtensions": {
      "@glint/environment-ember-template-imports": {
        "dependencies": {
          "ember-template-imports": "^3.0.0"
        },
        "peerDependencies": {
          "ember-template-imports": null
        }
      }
    },
    "peerDependencyRules": {
      "allowAny": [
        "typescript",
        "ember-source",
        "@glimmer/compiler",
        "@glimmer/syntax"
      ],
      "ignoreMissing": [
        "webpack",
        "rsvp"
      ]
    }
  },
  "volta": {
    "node": "20.10.0",
    "pnpm": "8.13.1"
  }
}

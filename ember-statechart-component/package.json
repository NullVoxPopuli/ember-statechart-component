{
  "name": "ember-statechart-component",
  "version": "6.1.2",
  "keywords": [
    "ember-addon"
  ],
  "description": "Use XState Machines *as* Components",
  "repository": "https://github.com/NullVoxPopuli/ember-statechart-component",
  "license": "MIT",
  "author": "NullVoxPopuli",
  "exports": {
    ".": "./dist/index.js",
    "./glint": "./dist/glint.js",
    "./*": "./dist/*",
    "./addon-main.js": "./addon-main.cjs"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ],
      "glint": [
        "./dist/glint.d.ts"
      ]
    }
  },
  "files": [
    "addon-main.cjs",
    "dist",
    "declarations",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "start": "concurrently \"npm:watch:*\"",
    "build": "concurrently \"npm:build:*\"",
    "build:js": "rollup -c ./rollup.config.mjs",
    "build:docs": "cp ../README.md ./README.md",
    "watch:js": "rollup -c --watch --no-watch.clearScreen",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\"",
    "lint:package": "publint",
    "lint:published-types": "attw --pack",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\" && pnpm format:prettier",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "format:prettier": "prettier . --write",
    "lint:prettier": "prettier . --check",
    "prepare": "pnpm build",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.0.0",
    "@glint/template": ">= 1.0.0"
  },
  "peerDependencies": {
    "xstate": "^5.5.1"
  },
  "devDependencies": {
    "@babel/core": "7.23.7",
    "@babel/eslint-parser": "^7.23.3",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-syntax-decorators": "7.23.3",
    "@babel/plugin-transform-typescript": "^7.18.6",
    "@babel/preset-typescript": "7.23.3",
    "@embroider/addon-dev": "4.1.3",
    "@glimmer/compiler": "^0.87.1",
    "@glimmer/component": "^1.0.4",
    "@glimmer/env": "^0.1.7",
    "@glint/core": "^1.2.2",
    "@glint/environment-ember-loose": "^1.2.2",
    "@glint/environment-ember-template-imports": "^1.2.2",
    "@glint/template": "^1.2.2",
    "@nullvoxpopuli/eslint-configs": "^3.2.2",
    "@rollup/plugin-babel": "^6.0.4",
    "@tsconfig/ember": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "concurrently": "^8.2.2",
    "decorator-transforms": "^1.0.3",
    "ember-cli-htmlbars": "^6.0.0",
    "ember-source": "~5.7.0-alpha.5",
    "ember-template-lint": "5.13.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-decorator-position": "^5.0.2",
    "eslint-plugin-ember": "^12.0.0",
    "eslint-plugin-import": "^2.24.1",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "npm-run-all": "4.1.5",
    "prettier": "^3.1.1",
    "rollup": "4.9.5",
    "typescript": "^5.3.3",
    "xstate": "^5.5.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "version": 2,
    "type": "addon",
    "main": "addon-main.cjs",
    "app-js": {}
  },
  "volta": {
    "extends": "../package.json"
  }
}
